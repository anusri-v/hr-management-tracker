GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=

DATABASE_URL=

# Generate with: npx cloak generate
PRISMA_FIELD_ENCRYPTION_KEY=

# Gmail OAuth2 for sending access request emails
MAIL_USER=
GOOGLE_REFRESH_TOKEN=

# HR notifications recipient(s) (access requests + reminder emails).
# Comma-separated for multiple, e.g. a@silq.net,b@shopup.org
HR_EMAIL=
# Timezone for reminder cron schedules (e.g. Asia/Kolkata)
REMINDER_CRON_TZ=

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=
# Frontend base URL used in outgoing email links
FRONTEND_URL=
# Session cookie security — for cross-site HTTPS set COOKIE_SECURE=true, COOKIE_SAMESITE=none
COOKIE_SECURE=
COOKIE_SAMESITE=
